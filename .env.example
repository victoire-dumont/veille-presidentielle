# Clés Supabase — à récupérer dans :
# Supabase Dashboard → Settings → API
#
# SUPABASE_URL : l'URL de ton projet (ex: https://abcdefgh.supabase.co)
# SUPABASE_SECRET_KEY : la "secret key" (pas la clé publique "anon")
#
# /!\ Ne jamais commiter le fichier .env (il est dans .gitignore)

SUPABASE_URL=https://ton-projet.supabase.co
SUPABASE_SECRET_KEY=ta-secret-key-ici
